# Local crAPI environment derived from the official OWASP/crAPI deploy/docker/.env setup.
# TODO:
# - Pin VERSION to a vetted release tag for stronger thesis reproducibility.
# - Add additional operator-tunable options if future target catalog entries need them.

VERSION=latest
LISTEN_IP=127.0.0.1
LOG_LEVEL=INFO
TLS_ENABLED=false
IDENTITY_SERVER_PORT=8080
COMMUNITY_SERVER_PORT=8087
WORKSHOP_SERVER_PORT=8000
CRAPI_PORT=8888
CRAPI_MAILHOG_PORT=8889
